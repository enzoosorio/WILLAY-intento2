# Copiar a .env y rellenar.

# ─── Firebase ───────────────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=willay-tas.firebaseapp.com
FIREBASE_PROJECT_ID=willay-tas
FIREBASE_STORAGE_BUCKET=willay-tas.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ─── Google Sign-In ─────────────────────────────────────────────────────────
# WEB: Firebase Console → Authentication → Sign-in method → Google → Web client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# IOS: Google Cloud Console → Credentials → OAuth 2.0 → crear tipo iOS, Bundle ID: pe.upc.willay
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# ANDROID: Google Cloud Console → Credentials → OAuth 2.0 → crear tipo Android + SHA-1 del debug.keystore
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ─── Emuladores ─────────────────────────────────────────────────────────────
USE_EMULATORS=true
EMULATOR_HOST=localhost

# ─── Visión facial ──────────────────────────────────────────────────────────
# Backend de reconocimiento facial: "remote" (backend), "mock" (Expo Go),
# "onnx" (dev build, no recomendado) o "facenet" (tfjs). Default: remote.
FACE_BACKEND=remote
# URL del endpoint remoto que devuelve embeddings faciales.
FACE_REMOTE_URL=https://us-central1-TU-PROYECTO.cloudfunctions.net/face_embed
# Solo para FACE_BACKEND=onnx: URL pública del modelo .onnx (se descarga y cachea).
FACE_MODEL_URL=https://github.com/enzoosorio/WILLAY-intento2/releases/download/version/w600k_mbf.onnx
# Solo para FACE_BACKEND=facenet: URL del model.json tfjs.
FACENET_MODEL_URL=
# (Legacy) compat: si FACE_BACKEND no se setea, USE_FACENET=true ⇒ facenet.
USE_FACENET=false

# ─── EAS ────────────────────────────────────────────────────────────────────
EAS_PROJECT_ID=
