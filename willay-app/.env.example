# Copiar a .env y rellenar.

# ─── Firebase ───────────────────────────────────────────────────────────────
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=willay-tas.firebaseapp.com
FIREBASE_PROJECT_ID=willay-tas
FIREBASE_STORAGE_BUCKET=willay-tas.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ─── Google Sign-In ─────────────────────────────────────────────────────────
# WEB: Firebase Console → Authentication → Sign-in method → Google → Web client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# IOS: Google Cloud Console → Credentials → OAuth 2.0 → crear tipo iOS, Bundle ID: pe.upc.willay
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# ANDROID: Google Cloud Console → Credentials → OAuth 2.0 → crear tipo Android + SHA-1 del debug.keystore
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ─── Emuladores ─────────────────────────────────────────────────────────────
USE_EMULATORS=true
EMULATOR_HOST=localhost

# ─── Visión facial ──────────────────────────────────────────────────────────
USE_FACENET=false

# ─── EAS ────────────────────────────────────────────────────────────────────
EAS_PROJECT_ID=
