{
  "expo": {
    "name": "Willay",
    "slug": "willay-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "willayapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pe.upc.willay",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Willay usa tu ubicación para reportes y alertas cercanas.",
        "NSCameraUsageDescription": "Willay usa la cámara para fichas de personas desaparecidas y avistamientos.",
        "NSPhotoLibraryUsageDescription": "Willay accede a tus fotos para subir fichas y avistamientos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "pe.upc.willay",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB-a8f4nOnPQRDy1WKleW-3qIGvf4SY0vk"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@react-native-firebase/app",
        {
          "android": "./google-services.json",
          "ios": "./GoogleService-Info.plist"
        }
      ],
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://maven.google.com"
            ]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Willay usa tu ubicación para reportes y alertas cercanas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Willay accede a tus fotos para subir fichas y avistamientos.",
          "cameraPermission": "Willay usa la cámara para fichas y avistamientos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#C8102E"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
